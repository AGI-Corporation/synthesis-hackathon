# ─── AgentPass Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env or .env.local to git.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── The Synthesis (filled automatically by register.py) ───────────────────────
SYNTHESIS_API_KEY=sk-synth-...
SYNTHESIS_PARTICIPANT_ID=
SYNTHESIS_TEAM_ID=
SYNTHESIS_PROJECT_ID=

# ── Human info (used by register.py so you don't have to retype) ──────────────
HUMAN_NAME=Your Full Name
HUMAN_EMAIL=you@example.com
HUMAN_HANDLE=@yourhandle
HUMAN_PROBLEM=Building privacy-preserving agentic infrastructure on Ethereum

# ── Web3 / Base Mainnet ───────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
DEPLOYER_PRIVATE_KEY=0x...

# ── Contract addresses (filled after deployment) ──────────────────────────────
AGENT_PASS_VERIFIER_ADDRESS=
ERC8004_REGISTRY_ADDRESS=

# ── Self Protocol ─────────────────────────────────────────────────────────────
SELF_PROTOCOL_API_KEY=
SELF_PROTOCOL_APP_ID=
